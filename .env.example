# Required
DATABASE_URL="file:./dev.db"

# Optional - enables AI-powered bot (works without it using simulated responses)
ANTHROPIC_API_KEY=sk-ant-...

# Optional - enables realtime voice agent (OpenAI Realtime API)
OPENAI_API_KEY=sk-...

# Optional - enables outbound callback via Vapi/Exitus (telco profile only)
# If unset, the callback button falls back to a simulated confirmation.
VAPI_OUTBOUND_URL=https://exitus-comms-api.dev.exituscloud.net/api/v1/calls/outbound

# Optional - demo configuration
DEMO_SEED_COUNT=300
SLA_PRIMERA_RESPUESTA_MIN=15
SLA_RESOLUCION_HORAS=24
