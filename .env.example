# Required
DATABASE_URL="file:./dev.db"

# Optional - enables AI-powered bot (works without it using simulated responses)
ANTHROPIC_API_KEY=sk-ant-...

# Optional - enables realtime voice agent (OpenAI Realtime API)
OPENAI_API_KEY=sk-...

# Optional - demo configuration
DEMO_SEED_COUNT=300
SLA_PRIMERA_RESPUESTA_MIN=15
SLA_RESOLUCION_HORAS=24
