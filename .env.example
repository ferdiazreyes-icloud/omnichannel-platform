# Environment Variables Template
# Copy this file to .env.local and fill in the values
# NEVER commit the actual .env.local file

# Required
ANTHROPIC_API_KEY=sk-ant-...          # Claude API key for the conversational bot
DATABASE_URL=file:./dev.db             # SQLite local database path

# Optional
DEMO_SEED_COUNT=300                    # Number of demo cases to generate in seed
SLA_PRIMERA_RESPUESTA_MIN=15          # Default first-response SLA in minutes
SLA_RESOLUCION_HORAS=24               # Default resolution SLA in hours
